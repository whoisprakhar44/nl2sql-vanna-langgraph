# ──────────────────────────────────────────────────────────────
# NL2SQL — Environment Configuration
# Copy to .env and fill in values for your local setup.
# ──────────────────────────────────────────────────────────────

# -- Ollama (local LLM) ---------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# -- ChromaDB (vector store) ----------------------------------------------
# Directory where ChromaDB persists embeddings.
CHROMA_PERSIST_DIR=./data/chroma_store

# -- Database --------------------------------------------------------------
# Path to your SQLite database (for future SQL execution steps).
DATABASE_PATH=./data/sample.db

# -- Retrieval tuning ------------------------------------------------------
# Maximum number of DDL chunks to retrieve per query.
RETRIEVAL_DDL_LIMIT=5
# Maximum number of documentation chunks to retrieve per query.
RETRIEVAL_DOC_LIMIT=3
# SQL examples are disabled by default to avoid template-copying behavior.
RETRIEVAL_INCLUDE_SQL_EXAMPLES=false
RETRIEVAL_SQL_LIMIT=0
# Maximum number of reranked tables included in SchemaContext.
RETRIEVAL_TABLE_LIMIT=8
# Foreign-key expansion depth from the seed tables.
RELATIONSHIP_EXPANSION_HOPS=1
# Reranking weights: semantic * 0.5 + keyword * 0.3 + relationship * 0.2.
RETRIEVAL_SCORE_SEMANTIC_WEIGHT=0.5
RETRIEVAL_SCORE_KEYWORD_WEIGHT=0.3
RETRIEVAL_SCORE_RELATIONSHIP_WEIGHT=0.2

# -- Metadata --------------------------------------------------------------
# Directory containing YAML metadata files for tables.
METADATA_DIR=./data/metadata

# -- Logging ---------------------------------------------------------------
LOG_LEVEL=INFO
